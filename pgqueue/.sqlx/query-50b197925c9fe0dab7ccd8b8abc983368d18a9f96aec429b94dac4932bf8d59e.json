  "db_name": "PostgreSQL",
  "query": "\n            SELECT\n                id,\n                unique_key,\n                queue,\n                name,\n                payload,\n                status AS \"status: JobStatus\",\n                priority,\n                group_key,\n                attempts,\n                max_attempts,\n                timeout_ms,\n                heartbeat_ms,\n                retry_delay_ms,\n                backoff AS \"backoff: JobRetryBackoff\",\n                ttl_ms,\n                scheduled_at,\n                enqueued_at,\n                started_at,\n                touched_at,\n                completed_at,\n                expires_at,\n                result,\n                error,\n                meta,\n                worker_id,\n                kind,\n                cron_expr,\n                GREATEST(\n                    enqueued_at,\n                    COALESCE(touched_at, enqueued_at),\n                    COALESCE(completed_at, enqueued_at)\n                ) AS \"updated_at!\"\n            FROM pgqueue.jobs\n            WHERE id = $1 AND queue = $2\n            ",
