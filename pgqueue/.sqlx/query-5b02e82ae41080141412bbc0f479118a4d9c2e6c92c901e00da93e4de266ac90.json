{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT id, queue, stats, metadata, started_at, heartbeat_at, expires_at\n            FROM pgqueue.workers\n            WHERE queue = $1\n              AND expires_at > now()\n              AND ($2::timestamptz IS NULL OR (started_at, id) > ($2, $3))\n            ORDER BY started_at, id\n            LIMIT $4\n            ",
