  "query": "\n            SELECT next_run_at\n            FROM pgqueue.cron_schedules\n            WHERE queue = $1 AND unique_key = $2\n              AND revision = $3 AND definition = $4\n              AND next_run_at <= now()\n            FOR UPDATE SKIP LOCKED\n            ",
